```{r filter ldl consensus data and visualize, warning=FALSE, message=FALSE}
# load ldl_consensus file
ldl_consensus <- read_csv("../input_files/consensus_taxa_results_ldl.csv")

# load ldl full taxa file
ldl_full_taxa <- read_csv("../input_files/filtered_tax_table_all_ldl.csv") %>%
  select(taxa, Phylum, Class, Order, Family, Genus, Species) %>%
  rename(taxon = taxa)

# Filter taxa with conflicting coefficients
filtered_ldl_consensus <- ldl_consensus %>%
  group_by(taxon, comparison) %>%
  mutate(
    coefficient_sign = sign(coefficient), # Get the sign of each coefficient
    consistent = n_distinct(coefficient_sign) == 1) %>% # Check if all signs are the same
  filter(consistent) %>% # Keep only consistent taxa
  select(-coefficient_sign, -consistent) # Remove helper columns

# inner join filtered consensus and full taxa files
filtered_ldl_consensus <- filtered_ldl_consensus %>%
  inner_join(ldl_full_taxa, by = "taxon")

# Match taxon id with taxonomy from LDL full taxonomy file
filtered_ldl_consensus <- filtered_ldl_consensus %>%
  mutate(
    taxon = case_when(
      taxon == "s__Azospirillum_sp_"                 
      ~ "o__Rhodospirillales;f__uncultured",
      taxon == "s__gut_metagenome_14"
      ~ "f__Oscillospiraceae;g__UCG_002;s__gut_metagenome",
      taxon == "s__uncultured_bacterium_4_15"
      ~ "f__Ruminococcaceae;g__CAG_352;s__uncultured_bacterium_4",
      taxon == "s__uncultured_bacterium_55"
      ~ "g__Eggerthella;s__uncultured_bacterium",
      taxon == "s__uncultured_organism_23"
      ~ "g__Akkermansia;s__uncultured_organism",
      taxon == "s__unidentified_1_2"
      ~ "g__Coprococcus;s__unidentified_1",
      TRUE                                          ~ taxon))
  
# Save the filtered data to a new file
write_csv(filtered_ldl_consensus, 
          "../output_files/ldl_consensus_taxa/filtered_ldl_consensus_taxa.csv")

# LDL comparisons as a factor
filtered_ldl_consensus <- filtered_ldl_consensus %>%
  mutate(
    comparison = factor(comparison, levels = c("Above Optimal_vs_Normal", 
                                               "Borderline High_vs_Normal", 
                                               "High_vs_Normal", 
                                               "Borderline High_vs_Above Optimal",
                                               "High_vs_Above Optimal",
                                               "High_vs_Borderline High")))

# Break long taxa names into multiple lines
filtered_ldl_consensus$taxon <- gsub("(s__.*)", "\n\\1", filtered_ldl_consensus$taxon)

# Generate a full grid for consistent spacing
grid_data <- expand.grid(
  comparison = unique(filtered_ldl_consensus$comparison),
  taxon = unique(filtered_ldl_consensus$taxon))

# Create the heatmap
ldl_consensus_hm <- ggplot(filtered_ldl_consensus, 
                           aes(x = comparison, y = taxon, fill = method_count)) +
  geom_tile(color = "black", size = 0.5) +  # Add black borders around every tile
  geom_tile(data = grid_data, aes(x = comparison, y = taxon),
            fill = NA, color = "black", size = 0.5) +  # Outline grid spaces
  scale_fill_gradient(
    low = "blue", high = "red", name = "Method Count",
    limits = c(0, 4),  # Adjust scale range as needed
    breaks = seq(0, 4, by = 1)) +  # Customize legend ticks
  labs(
    title = "Low Density Lipoprotein Consensus Taxa",
    x = "Comparison",
    y = "Taxon") +
  theme_minimal() +  # Use a clean theme
  theme(
    axis.text.x = element_text(angle = 45, hjust = 1),  # Rotate x-axis labels
    axis.text.y = element_text(size = 8),  # Adjust y-axis text size
    plot.title = element_text(size = 14, face = "bold", hjust = 0.5),  # Enhance title
    panel.grid = element_blank(),  # Remove default gridlines
    panel.border = element_blank()) +  # Remove panel border (already clean)
  coord_fixed() # Ensure square tiles and proper alignment
 

# Save the heatmap as a PNG file
ggsave("../output_files/ldl_consensus_taxa/ldl_consensus_heatmap.png", 
       ldl_consensus_hm, width = 10, height = 10, dpi = 300)

ldl_consensus_hm
