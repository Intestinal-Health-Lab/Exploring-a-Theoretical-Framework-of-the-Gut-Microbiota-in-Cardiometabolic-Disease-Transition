# correlation per taxon (Spearman)
cor_results <- correlation_data_long %>%
  group_by(taxon) %>%
  summarise(
    cor = cor(ldl, relative_abundance, method = "spearman", use = "pairwise.complete.obs"),
    p_value = suppressWarnings(cor.test(ldl, relative_abundance, method = "spearman")$p.value),
    .groups = "drop") %>%
  mutate(
    p_adj_BH = p.adjust(p_value, method = "BH"),
    signif = case_when(
      p_adj_BH <= 0.001 ~ "***",
      p_adj_BH <= 0.01  ~ "**",
      p_adj_BH <= 0.05  ~ "*",
      TRUE ~ ""
    ),
    label = paste0(round(cor, 2), "\n", signif)) # combine r + significance

# sort taxa by correlation
cor_results <- cor_results %>%
  arrange(cor) %>%
  mutate(taxon = factor(taxon, levels = taxon))

write_csv(cor_results, 
          "../output_files/corr_results_ldl.csv")

# heatmap of correlations
heatmap_plot <- ggplot(cor_results, aes(x = 1, y = taxon, fill = cor)) +
  geom_tile(color = "white") +
  geom_text(aes(label = label), size = 3.5, fontface = "bold") +
  scale_fill_gradient2(
    low = "blue", mid = "white", high = "red",
    midpoint = 0,
    name = "Spearman r") +
  labs(
    x = NULL,
    y = "Taxa",
    title = "Correlation of Taxa Abundance with LDL") +
  theme_minimal(base_size = 13) +
  theme(
    axis.text.x = element_blank(),
    axis.ticks.x = element_blank(),
    panel.grid = element_blank(),
    plot.title = element_text(hjust = 0.5))

# export png
ggsave(
  filename = "../input_files/ldl_taxa_correlation_heatmap.png",
  plot = heatmap_plot,
  width = 15,
  height = 8,
  dpi = 600,
  units = "in",
  bg = "white")

