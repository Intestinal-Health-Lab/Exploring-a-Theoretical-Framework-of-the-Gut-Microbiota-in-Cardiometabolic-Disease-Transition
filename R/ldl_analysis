```{r ANCOMBC2 analysis, warning=FALSE, message=FALSE}
##############################################################################
# ANCOMBC2 Differential Abundance Analysis
# - For each pair of 'ldl_cat' levels (Normal vs Above Optimal, etc.)
# - Include 'study' and 'sex' as covariates
##############################################################################

# Convert data to phyloseq object
otu_table <- otu_table(as.matrix(ldl_ft_table_filtered), taxa_are_rows = FALSE)
sample_data <- sample_data(ldl_meta)
physeq <- phyloseq(otu_table, sample_data)

# Define levels of ldl_cat
sample_data(physeq)$ldl_cat <- factor(sample_data(physeq)$ldl_cat, 
                                       levels = c("Normal", "Above Optimal", "Borderline High", "High"))

# Verify the levels
ldl_levels <- levels(sample_data(physeq)$ldl_cat)
print("Levels of 'ldl_cat':")
print(ldl_levels)

#run ANCOMBC on ldl category with study and sex as covariates
set.seed(123)
ancombc_results <- ancombc2(
  data = physeq,
  assay_name = "counts",                 # Count data
  fix_formula = "ldl_cat + study + sex + age_cat", # Fixed effects: LDL category with study and sex as covariates
  group = "ldl_cat",                     # Specify the grouping variable for multi-level tests
  p_adj_method = "hochberg",             # Adjust p-values using hochberg method
  prv_cut = 0,                           # Data pre-filtered, no prevalence cutoff needed
  lib_cut = 0,                           # Library size threshold
  alpha = 0.05,                          # Significance level
  global = TRUE,                         # Perform global test
  pairwise = TRUE,                       # Perform pairwise comparisons
  verbose = TRUE)                        # Enable detailed messages

# extract results
res <- ancombc_results$res %>%
  as.data.frame()

# write results csv file
write_csv(res, "../output_files/ancombc/ancombc_results_ldl_sex_cov_study_rand.csv")

# extract global results
res_global <- ancombc_results$res_global %>%
  as.data.frame()

# write global results csv file
write_csv(res_global, "../output_files/ancombc/ancombc_results_global_ldl_sex_cov_study_rand.csv")

# extract pairwise results
res_pairwise <- ancombc_results$res_pair %>%
  as.data.frame()

# write pairwise results csv file
write_csv(res_pairwise, "../output_files/ancombc/ancombc_pairwise_ldl_sex_cov_study_rand.csv")

# Check res_pairwise to Verify Column Names
colnames(res_pairwise)

# Filter Significant Taxa using the 'diff_*' columns to identify significant comparisons
significant_taxa <- res_pairwise %>%
  filter(`diff_ldl_catBorderline High` == TRUE |
         `diff_ldl_catHigh` == TRUE |
         `diff_ldl_catAbove Optimal` == TRUE |
         `diff_ldl_catBorderline High_ldl_catAbove Optimal` == TRUE |
         `diff_ldl_catHigh_ldl_catAbove Optimal` == TRUE |
         `diff_ldl_catHigh_ldl_catBorderline High` == TRUE)

# Write csv file
write_csv(significant_taxa, "../output_files/ancombc/significant_taxa_filtered.csv")
```

```{r metagenomeSeq analysis, warning=FALSE, message=FALSE}
##############################################################################
# MetagenomeSeq Differential Abundance Analysis
# - For each pair of 'ldl_cat' levels (Normal vs Above Optimal, etc.)
# - Include 'study' 'sex' and 'age_cat' as covariates
##############################################################################

# Transpose feature table to fit MetagenomeSeq's typical dimension (features x samples)
ldl_ft_table_mgs_filtered <- t(ldl_ft_table_filtered)

# Ensure 'Normal' is set as the reference level for ldl_cat
ldl_meta$ldl_cat <- factor(
  ldl_meta$ldl_cat,
  levels = c("Normal", "Above Optimal", "Borderline High", "High"))

# Create one MRexperiment object for the entire dataset
phenoData_full <- AnnotatedDataFrame(ldl_meta)
featureData_full <- AnnotatedDataFrame(
  data.frame(
    Feature = rownames(ldl_ft_table_mgs_filtered),
    row.names = rownames(ldl_ft_table_mgs_filtered)))

MRobj_full <- newMRexperiment(
  counts       = ldl_ft_table_mgs_filtered,
  phenoData    = phenoData_full,
  featureData  = featureData_full)

# Perform global CSS normalization across all samples
MRobj_full <- cumNorm(MRobj_full)

# Define all pairwise comparisons of the 4 levels
pairwise_comparisons <- combn(levels(ldl_meta$ldl_cat), 2, simplify = FALSE)

# Loop through each pairwise comparison
for (pair in pairwise_comparisons) {
  # Label for the comparison (placing pair[2] first in the name)
  display_comparison_name <- paste(pair[2], pair[1], sep = "_vs_")
  message("Running pairwise comparison: ", display_comparison_name)
  
  # Identify which samples belong to these two levels
  sub_index <- pData(MRobj_full)$ldl_cat %in% pair
  
  # Subset the already-normalized MRexperiment object
  MRobj_subset <- MRobj_full[, sub_index]
  
  # Re-factor ldl_cat so pair[1] is baseline and pair[2] is tested
  pData(MRobj_subset)$ldl_cat <- factor(pData(MRobj_subset)$ldl_cat, levels = pair)
  
  # Verify that we have samples in this subset
  if (ncol(MRobj_subset) == 0) {
    message("No matching samples found for comparison: ", display_comparison_name)
    next}
  
  # Build the model matrix for this subset
  model_matrix <- model.matrix(~ ldl_cat + study + sex + age_cat, data = pData(MRobj_subset))
  
  # Fit the model using fitZig
  fit <- tryCatch({
    fitZig(MRobj_subset, mod = model_matrix)}, 
    error = function(e) {
    message("Error running fitZig for ", display_comparison_name, ": ", e$message)
    return(NULL)})
  
  if (is.null(fit)) {
    next}
  
  # Save MRexperiment subset object if desired
  MRobj_filename <- paste0("../output_files/metagenomeSeq/MRobj_", display_comparison_name, ".RDS")
  saveRDS(MRobj_subset, file = MRobj_filename)
  message("Saved subset MRexperiment to ", MRobj_filename)
  
  # Extract results with built-in FDR correction
  res <- tryCatch({
    MRcoefs(fit, adjustMethod = "hochberg")  # or "BH"/"fdr"
  }, error = function(e) {
    message("Error extracting results for ", display_comparison_name, ": ", e$message)
    return(NULL)
  })
  
  if (is.null(res)) {
    next
  }
  
  # Convert results to a data frame
  res_df <- as.data.frame(res)
  res_df$contrast <- display_comparison_name
  
  # 11) Filter significant taxa (adjust as desired)
  res_sig <- res_df %>%
    filter(adjPvalues < 0.1) %>%
    arrange(adjPvalues)
  
  if (nrow(res_sig) == 0) {
    message("No significant taxa found for contrast: ", display_comparison_name)
    next
  }
  
  # Save results to a CSV file
  output_csv <- file.path(
    "../output_files/metagenomeSeq", 
    paste0(display_comparison_name, "_pairwise_results.csv")
  )
  write.csv(res_sig, file = output_csv, row.names = TRUE)
  
  message("Saved results for contrast: ", display_comparison_name)
}

message("All pairwise comparisons completed successfully.")
```

