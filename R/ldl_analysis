``` {r DeSeq2, warning=FALSE, message=FALSE}
##############################################################################
# DESeq2 Pairwise Differential Abundance Analysis
# - For each pair of 'ldl_cat' levels (Normal vs Above Optimal, etc.)
# - Include 'study' and 'sex' as covariates
##############################################################################

# Transpose feature table to match DESeq2's requirements (rows = features, columns = samples)
ldl_ft_table_deseq2 <- ldl_ft_table_filtered %>%
  t() %>%
  as.data.frame()

# Ensure rownames of ldl_meta match colnames of the feature table
if (!all(colnames(ldl_ft_table_deseq2) %in% rownames(ldl_meta))) {
  stop("Sample IDs in the feature table do not match those in the metadata.")
  }

# Reorder metadata to match the feature table
ldl_meta <- ldl_meta[colnames(ldl_ft_table_deseq2), ]

# Ensure correct variable types in metadata
ldl_meta <- ldl_meta %>%
  mutate(
    ldl_cat = factor(ldl_cat, levels = c("Normal", "Above Optimal", "Borderline High", "High")))  # LDL category as a factor

# Create DESeq2 dataset
dds <- DESeqDataSetFromMatrix(
  countData = ldl_ft_table_deseq2,
  colData = ldl_meta,
  design = ~ ldl_cat + study + sex + age_cat)

# Perform DESeq2 analysis with size factors set to 'poscounts'
dds <- dds %>%
  estimateSizeFactors(type = "poscounts") %>%
  DESeq()

# Define pairwise comparisons based on levels of ldl_cat
ldl_levels <- levels(ldl_meta$ldl_cat)
pairwise_comparisons <- combn(ldl_levels, 2, simplify = FALSE)

# Initialize a list to store results
results_list <- list()

# Loop through each pairwise comparison
for (pair in pairwise_comparisons) {
  # Define comparison name
  comparison_name <- paste(pair[2], "vs", pair[1], sep = "_")
  message("Processing comparison: ", comparison_name)
  
  # Perform DESeq2 analysis for the pair
  res <- results(
    dds,
    contrast = c("ldl_cat", pair[2], pair[1]))  # pair[2] (numerator) compared to pair[1] (denominator)
  
  # Save results to the list
  results_list[[comparison_name]] <- res
  
  # Write results to a CSV file
  write.csv(
    as.data.frame(res),
    file = paste0("../output_files/DESeq2/DESeq2_", comparison_name, "_results.csv"),
    row.names = TRUE)}

# Final Message
message("All pairwise comparisons completed successfully.")

