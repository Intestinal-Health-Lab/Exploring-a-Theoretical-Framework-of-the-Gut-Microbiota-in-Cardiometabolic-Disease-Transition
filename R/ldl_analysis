  sample_data(physeq2)$ldl_cat <- factor(sample_data(physeq2)$ldl_cat, 
                                         levels = c("Normal", "Above Optimal", "Borderline High", "High"))

# Verify the levels
ldl_levels <- levels(sample_data(physeq2)$ldl_cat)
print("Levels of 'ldl_cat':")
print(ldl_levels)

# Ensure there are at least two levels
if(length(ldl_levels) < 2) {
  stop("Error: 'ldl_cat' must have at least two levels for pairwise comparisons.")
}

# Define Pairwise Comparisons
# Generate all unique pairwise combinations of ldl_cat levels
pairwise_comparisons <- combn(ldl_levels, 2, simplify = FALSE)

# Loop through each pairwise comparison
for(pair in pairwise_comparisons) {
  
  # Flip the naming in the output files so the tested group is first
  display_comparison_name <- paste(pair[2], pair[1], sep = "_vs_")
  message("Running corncob for comparison: ", display_comparison_name)
  
  # Subset Phyloseq Object
  physeq_subset <- subset_samples(physeq2, ldl_cat %in% pair)
  physeq_subset <- prune_taxa(taxa_sums(physeq_subset) > 0, physeq_subset)
  sample_data(physeq_subset)$ldl_cat <- factor(sample_data(physeq_subset)$ldl_cat, levels = pair)
  
  # Run Corncob Differential Abundance Test
  corncob_res <- tryCatch({
      differentialTest(
        formula = ~ ldl_cat + study + sex + age_cat,
        formula_null = ~ study + sex + age_cat,
        phi.formula = ~ ldl_cat + study + sex + age_cat,
        phi.formula_null = ~ ldl_cat + study + sex + age_cat,
        test = "Wald",
        boot = FALSE,
        data = physeq_subset,
        fdr_cutoff = 0.1
      )
    }, error = function(e) {
      message("Error running corncob for comparison ", display_comparison_name, ": ", e$message)
      return(NULL)
    })
  
  if(is.null(corncob_res) || length(corncob_res$significant_taxa) == 0) {
    message("No significant taxa found for comparison: ", display_comparison_name)
    next
  }
  
  # Save corncob_res object for manual inspection
  corncob_res_filename <- paste0("../output_files/corncob/corncob_res_", display_comparison_name, ".RDS")
  saveRDS(corncob_res, file = corncob_res_filename)
  message("Saved corncob_res object to ", corncob_res_filename)
  
  # Extract Results with Accurate Matching
  # 'pair[2]' is the tested group, so the coefficient name is "ldl_cat<tested_group>"
  comparison_variable <- paste0("ldl_cat", pair[2])
  corncob_sig_df <- data.frame(
    Taxon = corncob_res$significant_taxa,
    p_value = sapply(seq_along(corncob_res$significant_taxa), function(i) {
      if (corncob_res$significant_taxa[i] %in% names(corncob_res$p)) {
        return(corncob_res$p[[corncob_res$significant_taxa[i]]])
      }
      return(NA)
    }),
    p_value_fdr = sapply(seq_along(corncob_res$significant_taxa), function(i) {
      if (corncob_res$significant_taxa[i] %in% names(corncob_res$p_fdr)) {
        return(corncob_res$p_fdr[[corncob_res$significant_taxa[i]]])
      }
      return(NA)
    }),
    coefficient = sapply(seq_along(corncob_res$significant_models), function(i) {
      model <- corncob_res$significant_models[[i]]
      if (!is.null(model$coefficients)) {
        coef_row <- grep(paste0("^mu\\.", comparison_variable, "$"), rownames(model$coefficients))
        if (length(coef_row) > 0) {
          return(model$coefficients[coef_row, "Estimate"])
        }
      }
      return(NA)
    }),
    stringsAsFactors = FALSE
  )
  
  # Filter significant taxa
  corncob_sig_df <- corncob_sig_df %>%
    filter(p_value < 0.05 & p_value_fdr < 0.1)
  
  if(nrow(corncob_sig_df) == 0) {
    message("No significant taxa passed the filtering criteria for comparison: ", display_comparison_name)
    next
  }
  
  # Save Significant Corncob Results as CSV
  csv_filename <- paste0("corncob_", display_comparison_name, "_significant_results.csv")
  write.csv(corncob_sig_df, file = paste0("../output_files/corncob/", csv_filename), row.names = FALSE)
  message("Saved significant corncob results to ../output_files/corncob/", csv_filename)
  
  message(nrow(corncob_sig_df), " significant taxa found for comparison: ", display_comparison_name)
}
# Summary message
message("All pairwise corncob analyses completed.")
