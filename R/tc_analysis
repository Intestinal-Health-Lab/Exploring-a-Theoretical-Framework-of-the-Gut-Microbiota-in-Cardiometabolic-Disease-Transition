```{r ANCOMBC2, warning=FALSE, message=FALSE}
##############################################################################
# ANCOMBC2 Differential Abundance Analysis
# - For each pair of 'tc_cat' levels (Desirable vs Borderline High, etc.)
# - Include 'study' 'sex' and 'age_cat' as covariates
##############################################################################

# Convert tables to phyloseq object
otu_table <- otu_table(as.matrix(tc_ft_table_filtered), taxa_are_rows = FALSE)
sample_data <- sample_data(tc_meta)
physeq <- phyloseq(otu_table, sample_data)

# Define levels of the variable of interest
sample_data(physeq)$tc_cat <- factor(sample_data(physeq)$tc_cat, 
                                       levels = c("Desirable", "Borderline High", "High"))

#run ANCOMBC on tc category with sex as a covariate and study as a random effect
set.seed(123)
ancombc_results <- ancombc2(
  data = physeq,
  assay_name = "counts",                 # Count data
  fix_formula = "tc_cat + study + sex + age_cat",  # Fixed effects: tc category with sex as a covariate
  group = "tc_cat",                      # Specify the grouping variable for multi-level tests
  p_adj_method = "hochberg",             # Adjust p-values using hochberg method
  prv_cut = 0,                           # Data pre-filtered, no prevalence cutoff needed
  lib_cut = 0,                           # Library size threshold
  alpha = 0.05,                          # Significance level
  global = TRUE,                         # Perform global test
  pairwise = TRUE,                       # Perform pairwise comparisons
  verbose = TRUE)                        # Enable detailed messages

# extract results
res <- ancombc_results$res %>%
  as.data.frame()

# write global results csv file
write_csv(res, "../output_files/ancombc/ancombc_results_tc_sex_cov_study_rand.csv")

# extract global results
res_global <- ancombc_results$res_global %>%
  as.data.frame()

# write global results csv file
write_csv(res_global, "../output_files/ancombc/ancombc_results_tc_sex_cov_study_rand.csv")

# extract pairwise results
res_pairwise <- ancombc_results$res_pair %>%
  as.data.frame()

# write pairwise results csv file
write_csv(res_pairwise, "../output_files/ancombc/ancombc_pairwise_tc_sex_cov_study_rand.csv")

#identify column names for filtering significant taxa and visualizing
colnames(res_pairwise)

# Filter Significant Taxa
significant_taxa <- res_pairwise %>%
  filter(`diff_tc_catBorderline High` == TRUE |
         `diff_tc_catHigh` == TRUE |
         `diff_tc_catHigh_tc_catBorderline High` == TRUE)

# Save Filtered Taxa to CSV
write_csv(significant_taxa, "../output_files/ancombc/significant_taxa_tc_filtered.csv")
```

```{r metagenomeSeq analysis, warning=FALSE, message=FALSE}
##############################################################################
# MetagenomeSeq Differential Abundance Analysis
# - For each pair of 'tc_cat' levels (Desirable vs Borderline High, etc.)
# - Include 'study' and 'sex' as covariates
##############################################################################

# Transpose feature table for input into MetagenomeSeq
tc_ft_table_mgs_filtered <- tc_ft_table_filtered %>%
  t()

# Check that metadata and feature table have matching sample IDs
all(colnames(tc_ft_table_mgs_filtered) %in% rownames(tc_meta))

# Ensure 'Normal' is set as the reference level for tc_cat
tc_meta$tc_cat <- factor(
  tc_meta$tc_cat,
  levels = c("Desirable", "Borderline High", "High"))

# Create one MRexperiment object for the entire dataset
phenoData_full <- AnnotatedDataFrame(tc_meta)
featureData_full <- AnnotatedDataFrame(
  data.frame(
    Feature = rownames(tc_ft_table_mgs_filtered),
    row.names = rownames(tc_ft_table_mgs_filtered)
  )
)

MRobj_full <- newMRexperiment(
  counts       = tc_ft_table_mgs_filtered,
  phenoData    = phenoData_full,
  featureData  = featureData_full
)

# Perform global CSS normalization across all samples
MRobj_full <- cumNorm(MRobj_full)

# Define all pairwise comparisons of the 4 levels
pairwise_comparisons <- combn(levels(tc_meta$tc_cat), 2, simplify = FALSE)

# Loop through each pairwise comparison
for (pair in pairwise_comparisons) {
  # Label for the comparison (placing pair[2] first in the name)
  display_comparison_name <- paste(pair[2], pair[1], sep = "_vs_")
  message("Running pairwise comparison: ", display_comparison_name)
  
  # Identify which samples belong to these two levels
  sub_index <- pData(MRobj_full)$tc_cat %in% pair
  
  # Subset the already-normalized MRexperiment object
  MRobj_subset <- MRobj_full[, sub_index]
  
  # Re-factor tc_cat so pair[1] is baseline and pair[2] is tested
  pData(MRobj_subset)$tc_cat <- factor(pData(MRobj_subset)$tc_cat, levels = pair)
  
  # Verify that we have samples in this subset
  if (ncol(MRobj_subset) == 0) {
    message("No matching samples found for comparison: ", display_comparison_name)
    next
  }
  
  # Build the model matrix for this subset
  model_matrix <- model.matrix(~ tc_cat + study + sex + age_cat, data = pData(MRobj_subset))
  
  # Fit the model using fitZig
  fit <- tryCatch({
    fitZig(MRobj_subset, mod = model_matrix)
  }, error = function(e) {
    message("Error running fitZig for ", display_comparison_name, ": ", e$message)
    return(NULL)
  })
  
  if (is.null(fit)) {
    next
  }
  
  # Save MRexperiment subset object if desired
  MRobj_filename <- paste0("../output_files/metagenomeSeq/MRobj_", display_comparison_name, ".RDS")
  saveRDS(MRobj_subset, file = MRobj_filename)
  message("Saved subset MRexperiment to ", MRobj_filename)
  
  # Extract results with built-in FDR correction
  res <- tryCatch({
    MRcoefs(fit, adjustMethod = "hochberg")  # or "BH"/"fdr"
  }, error = function(e) {
    message("Error extracting results for ", display_comparison_name, ": ", e$message)
    return(NULL)
  })
  
  if (is.null(res)) {
    next
  }
  
  # Convert results to a data frame
  res_df <- as.data.frame(res)
  res_df$contrast <- display_comparison_name
  
  # 11) Filter significant taxa (adjust as desired)
  res_sig <- res_df %>%
    filter(adjPvalues < 0.1) %>%
    arrange(adjPvalues)
  
  if (nrow(res_sig) == 0) {
    message("No significant taxa found for contrast: ", display_comparison_name)
    next
  }
  
  # Save results to a CSV file
  output_csv <- file.path(
    "../output_files/metagenomeSeq", 
    paste0(display_comparison_name, "_pairwise_results.csv")
  )
  write.csv(res_sig, file = output_csv, row.names = TRUE)
  
  message("Saved results for contrast: ", display_comparison_name)
}

message("All pairwise comparisons completed successfully.")
```

```{r corncob analysis, warning=FALSE, message=FALSE}
##############################################################################
# Corncob Pairwise Differential Abundance Analysis
# - For each pair of 'tc_cat' levels (Desirable vs Borderline High, etc.)
# - Include 'study' and 'sex' as covariates
##############################################################################

# Convert tables to phyloseq object
otu_table <- otu_table(as.matrix(tc_ft_table_filtered), taxa_are_rows = FALSE)
sample_data <- sample_data(tc_meta)
physeq2 <- phyloseq(otu_table, sample_data)

# Check if 'tc_cat' is a factor
is_factor <- is.factor(sample_data(physeq2)$tc_cat)
print(paste("'tc_cat' is a factor:", is_factor))

# If not, convert it to a factor with appropriate levels
if(!is_factor) {
  # Inspect unique values to define levels correctly
  unique_tc <- unique(sample_data(physeq2)$tc_cat)
  print("Unique 'tc_cat' values:")
  print(unique_tc)
  
  # Define levels of the variable of interest
  sample_data(physeq2)$tc_cat <- factor(sample_data(physeq2)$tc_cat, 
                                         levels = c("Desirable", "Borderline High", "High"))
}

# Verify the levels
tc_levels <- levels(sample_data(physeq2)$tc_cat)
print("Levels of 'tc_cat':")
print(tc_levels)

# Ensure there are at least two levels
if(length(tc_levels) < 2) {
  stop("Error: 'tc_cat' must have at least two levels for pairwise comparisons.")
}

# Define Pairwise Comparisons
# Generate all unique pairwise combinations of tc_cat levels
pairwise_comparisons <- combn(tc_levels, 2, simplify = FALSE)

# Loop through each pairwise comparison
for(pair in pairwise_comparisons) {
  
  # Flip the naming in the output files so the tested group is first
  display_comparison_name <- paste(pair[2], pair[1], sep = "_vs_")
  message("Running corncob for comparison: ", display_comparison_name)
  
  # Subset Phyloseq Object
  physeq_subset <- subset_samples(physeq2, tc_cat %in% pair)
  physeq_subset <- prune_taxa(taxa_sums(physeq_subset) > 0, physeq_subset)
  sample_data(physeq_subset)$tc_cat <- factor(sample_data(physeq_subset)$tc_cat, levels = pair)
  
  # Run Corncob Differential Abundance Test
  corncob_res <- tryCatch({
      differentialTest(
        formula = ~ tc_cat + study + sex + age_cat,
        formula_null = ~ study + sex + age_cat,
        phi.formula = ~ tc_cat + study + sex + age_cat,
        phi.formula_null = ~ tc_cat + study + sex + age_cat,
        test = "Wald",
        boot = FALSE,
        data = physeq_subset,
        fdr_cutoff = 0.1
      )
    }, error = function(e) {
      message("Error running corncob for comparison ", display_comparison_name, ": ", e$message)
      return(NULL)
    })
  
  if(is.null(corncob_res) || length(corncob_res$significant_taxa) == 0) {
    message("No significant taxa found for comparison: ", display_comparison_name)
    next
  }
  
  # Save corncob_res object for manual inspection
  corncob_res_filename <- paste0("../output_files/corncob/corncob_res_", display_comparison_name, ".RDS")
  saveRDS(corncob_res, file = corncob_res_filename)
  message("Saved corncob_res object to ", corncob_res_filename)
  
  # Extract Results with Accurate Matching
  # 'pair[2]' is the tested group, so the coefficient name is "tc_cat<tested_group>"
  comparison_variable <- paste0("tc_cat", pair[2])
  corncob_sig_df <- data.frame(
    Taxon = corncob_res$significant_taxa,
    p_value = sapply(seq_along(corncob_res$significant_taxa), function(i) {
      if (corncob_res$significant_taxa[i] %in% names(corncob_res$p)) {
        return(corncob_res$p[[corncob_res$significant_taxa[i]]])
      }
      return(NA)
    }),
    p_value_fdr = sapply(seq_along(corncob_res$significant_taxa), function(i) {
      if (corncob_res$significant_taxa[i] %in% names(corncob_res$p_fdr)) {
        return(corncob_res$p_fdr[[corncob_res$significant_taxa[i]]])
      }
      return(NA)
    }),
    coefficient = sapply(seq_along(corncob_res$significant_models), function(i) {
      model <- corncob_res$significant_models[[i]]
      if (!is.null(model$coefficients)) {
        coef_row <- grep(paste0("^mu\\.", comparison_variable, "$"), rownames(model$coefficients))
        if (length(coef_row) > 0) {
          return(model$coefficients[coef_row, "Estimate"])
        }
      }
      return(NA)
    }),
    stringsAsFactors = FALSE
  )
  
  # Filter significant taxa
  corncob_sig_df <- corncob_sig_df %>%
    filter(p_value < 0.05 & p_value_fdr < 0.1)
  
  if(nrow(corncob_sig_df) == 0) {
    message("No significant taxa passed the filtering criteria for comparison: ", display_comparison_name)
    next
  }
  
  # Save Significant Corncob Results as CSV
  csv_filename <- paste0("corncob_", display_comparison_name, "_significant_results.csv")
  write.csv(corncob_sig_df, file = paste0("../output_files/corncob/", csv_filename), row.names = FALSE)
  message("Saved significant corncob results to ../output_files/corncob/", csv_filename)
  
  message(nrow(corncob_sig_df), " significant taxa found for comparison: ", display_comparison_name)
}

# Summary message
message("All pairwise corncob analyses completed.")
