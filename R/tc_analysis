```{r prepare data for correlations of heatmap taxa with LDL levels, warning=FALSE, message=FALSE}
# extract normalized ASV table
tc_asv_abund <- norm_tc_TSS$taxa_abund$ASV %>%
  rownames_to_column() %>%
  as.data.frame() %>%
  rename(taxon = rowname)

# view normalized ASV table
View(tc_asv_abund)

# Split taxa in ldl_asv_abund into separate columns
tc_asv_abund_separated <- tc_asv_abund %>%
  separate(
    col = taxon,
    into = c("Phylum", "Class", "Order", "Family", "Genus", "Species", "Alt_Genus"),
    sep = "\\|",
    fill = "right") %>%
  select(-"Phylum", -"Class", -"Order", -"Family", -"Genus", -"Species", ) %>%
  rename(taxon = Alt_Genus)

View(tc_asv_abund_separated)

# read in cross parameter consensus heatmap data
cross_parameter_consensus <- read_csv("../input_files/all_consensus_filtered.csv") %>%
  select(taxon)

# match taxa names from consensus analysis to asv abund
tc_asv_abund_match_hm <- tc_asv_abund_separated %>%
  mutate(taxon = case_when(
    taxon == "s__uncultured_bacterium_87"
    ~ "f__Lachnospiraceae;g__Eubacterium_ruminantium_group;s__uncultured_bacterium", 
    taxon == "s__gut_metagenome_14"
    ~ "f__Oscillospiraceae;g__UCG_002;s__gut_metagenome",
    taxon == "s__uncultured_bacterium_4_15"
    ~ "f__Ruminococcaceae;g__CAG_352;s__uncultured_bacterium_4",
    taxon == "s__uncultured_bacterium_1_22"
    ~ "g__Akkermansia;s__uncultured_bacterium_1", 
    taxon == "s__uncultured_bacterium_55"
    ~ "g__Eggerthella;s__uncultured_bacterium", 
    taxon == "s__uncultured_organism_23"
    ~ "g__Izemoplasmatales;s__uncultured_organism", 
    taxon == "s__Lachnospiraceae_bacterium"
    ~ "g__Lachnospiraceae_UCG_001;s__Lachnospiraceae_bacterium",
    taxon == "s__metagenome_2_1"
    ~ "g__Ruminococcus;s__metagenome_2",
    TRUE ~ taxon))
  
correlation_data <- cross_parameter_consensus %>%
  distinct(taxon, .keep_all = TRUE) %>%  # keep the first instance of each taxon
  left_join(tc_asv_abund_match_hm, by = "taxon") %>%
  filter(
    !taxon %in% c(
      "g__Izemoplasmatales;s__uncultured_organism")) %>%
  as.data.frame() %>% 
  column_to_rownames( var = "taxon") %>%
  t() %>%
  as.data.frame() %>%
  rownames_to_column(var = "sample_id")
  
raw_data_tc <- read_csv("../input_files/raw_data_baseline.csv")

correlation_data2 <- left_join(
  correlation_data,
  raw_data_tc,
  by = "sample_id") %>%
  select(-study,-sex, -age, -age_cat, -bmi, -bmi_cat,
         -sys_press, -dia_press, -bp_cat, -ldl, -ldl_cat,
         -rhi, -rhi_cat)

correlation_data_long <- correlation_data2 %>%
  pivot_longer(
    cols = -c(sample_id, tc, tc_cat),
    names_to = "taxon",
    values_to = "relative_abundance")
```

```{r run correlations and visualize using ggplot, message=FALSE, warning=FALSE}
# correlation per taxon (Spearman)
cor_results <- correlation_data_long %>%
  group_by(taxon) %>%
  summarise(
    cor = cor(tc, relative_abundance, method = "spearman", use = "pairwise.complete.obs"),
    p_value = suppressWarnings(cor.test(tc, relative_abundance, method = "spearman")$p.value),
    .groups = "drop") %>%
  mutate(
    p_adj_BH = p.adjust(p_value, method = "BH"),
    signif = case_when(
      p_adj_BH <= 0.001 ~ "***",
      p_adj_BH <= 0.01  ~ "**",
      p_adj_BH <= 0.05  ~ "*",
      TRUE ~ ""
    ),
    label = paste0(round(cor, 2), "\n", signif)) # combine r + significance

# sort taxa by correlation
cor_results <- cor_results %>%
  arrange(cor) %>%
  mutate(taxon = factor(taxon, levels = taxon))

write_csv(cor_results, 
          "../output_files/corr_results_tc.csv")

# heatmap of correlations
heatmap_plot <- ggplot(cor_results, aes(x = 1, y = taxon, fill = cor)) +
  geom_tile(color = "white") +
  geom_text(aes(label = label), size = 3.5, fontface = "bold") +
  scale_fill_gradient2(
    low = "blue", mid = "white", high = "red",
    midpoint = 0,
    name = "Spearman r") +
  labs(
    x = NULL,
    y = "Taxa",
    title = "Correlation of Taxa Abundance with TC") +
  theme_minimal(base_size = 13) +
  theme(
    axis.text.x = element_blank(),
    axis.ticks.x = element_blank(),
    panel.grid = element_blank(),
    plot.title = element_text(hjust = 0.5))

# export png
ggsave(
  filename = "../input_files/tc_taxa_correlation_heatmap.png",
  plot = heatmap_plot,
  width = 15,
  height = 8,
  dpi = 600,
  units = "in",
  bg = "white")

heatmap_plot
