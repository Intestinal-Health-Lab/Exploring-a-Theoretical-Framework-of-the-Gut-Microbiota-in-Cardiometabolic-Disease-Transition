```{r network comparison, message=FALSE, warning=FALSE}
# first create a list
tc_network <- list()

# select samples of "IW" group
# use clone to get a deep copy of tc_network (R6 object)
tmp <- clone(mt)

# change sample_table directly
tmp$sample_table %<>% subset(
  tc_cat == "Desirable")

# trim all files in the object
tmp$tidy_dataset()
tmp

tmp$add_rownames2taxonomy("ASV")
# then we can calculate the relative abundance of ASV
# for all taxonomic levels like common operation
tmp$cal_abund()

# use filter_thres parameter to filter the feature with low relative abundance
tmp <- trans_network$new(
  dataset = tmp, 
  cor_method = "sparcc", 
  use_sparcc_method = "SpiecEasi")

# COR_p_thres represents the p value threshold
tmp$cal_network(
  network_method = "SpiecEasi", 
  COR_p_thres = 0.01)

# put the network into the list
tc_network$tc_desirable <- tmp

# select samples of "TW" group
tmp <- clone(mt)

tmp$sample_table %<>% subset(
  tc_cat == "Borderline High")

# trim all files in the object
tmp$tidy_dataset()
tmp

tmp$add_rownames2taxonomy("ASV")
# then we can calculate the relative abundance of ASV
# for all taxonomic levels like common operation
tmp$cal_abund()

tmp <- trans_network$new(
  dataset = tmp,
  cor_method = "sparcc", 
  use_sparcc_method = "SpiecEasi")

# COR_p_thres represents the p value threshold
tmp$cal_network(
  network_method = "SpiecEasi", 
  COR_p_thres = 0.01)

