```{r alpha shannons diversity phylum level, warning=FALSE, message=FALSE}
# phylum level alpha diversity measure via Shannons diveristy index
# rename outputs from PerformAlphaDiversityComp with _shannons_phylum_age
# move to output_files/alphadiversity
mbSet<-PlotAlphaData(mbSet, 
                     "filt","../output_files/alphadiversity/alpha_diver_shannons_phylum_age",
                     "Shannon","age_cat","Phylum", "default", "png");
mbSet<-PlotAlphaBoxData(mbSet, 
                        "../output_files/alphadiversity/alpha_diverbox_shannons_phylum_age",
                        "Shannon","age_cat","default", "png");
mbSet<-PerformAlphaDiversityComp(mbSet, 
                                 "nonpar","age_cat","true");
ad_phy_age_sig <- mbSet[["analSet"]][["alpha.stat.info"]];
ad_phy_age_sig_df <- as.data.frame(ad_phy_age_sig);
write_csv(ad_phy_age_sig_df, 
          "../output_files/alphadiversity/ad_phy_age_sig_shannons.csv")
```

