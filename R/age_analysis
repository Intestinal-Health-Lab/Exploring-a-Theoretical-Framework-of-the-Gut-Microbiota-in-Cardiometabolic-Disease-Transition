```{r load libraries, warning=FALSE, message=FALSE, echo=FALSE}
# Load necessary libraries
library(tidyverse)
library(MicrobiomeAnalystR)
library(ecodist)
library(Cairo)
```

```{r copy age input files, warning=FALSE, message=FALSE}
#copy age feature/taxa table
file.copy(
  "../../drivers_baseline_file_handling/output_files/ft_tax_merged.csv", 
  "../input_files/ft_tax_merged.csv",
  overwrite = FALSE)

#copy age metadata
file.copy(
  "../../drivers_baseline_file_handling/output_files/bmi_sex_study_age_meta_baseline.csv", 
  "../input_files/bmi_sex_study_age_meta_baseline.csv",
  overwrite = FALSE)
```

```{r create phyloseq object, warning=FALSE, message=FALSE}
# Initiate the mbSetObj
mbSet<-Init.mbSetObj()

# Set the analysis type
mbSet<-SetModuleType(mbSet, "mdp")

# Read in the feature/taxonomy table
mbSet<-Read16SAbundData(mbSet, 
                        dataName="../input_files/ft_tax_merged.csv", 
                        format="text",
                        taxa_type="SILVA", 
                        ismetafile="F", 
                        is.normalized = "F")

# Read in the metadata file
mbSet<-ReadSampleTable(mbSet, "../input_files/bmi_sex_study_age_meta_baseline.csv")

# Data integrity check
mbSet<-SanityCheckData(mbSet, filetype="text")

# Create phyloseq object
mbSet<-CreatePhyloseqObj(mbSet, type="text", 
                         taxa_type="SILVA", 
                         taxalabel="T", 
                         isNormInput = FALSE)
```

```{r low abundance filtering, warning=FALSE, message=FALSE}
# Low abundance filtering, based on the prevalence of features. In this case, by setting the sample percentage to 0.1, only features with >4 counts in at least 10% of all samples will be retained.
mbSet<-ApplyAbundanceFilter(mbSet, 
                            filt.opt="prevalence", 
                            count=4, 
                            smpl.perc=0.1)
```

```{r total sum scaling, warning=FALSE, message=FALSE}
#Normalization with no rarefying, total sum scaling and no transformation
mbSet<-PerformNormalization(mbSet, 
                            rare.opt="none", 
                            scale.opt="colsum", 
                            transform.opt="none")
```

