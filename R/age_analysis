```{r beta diversity phylum level, warning=FALSE, message=FALSE}
# phylum level beta diversity measured via Bray Curtis Diversity index permanova
#rename outputs from PerformCategoryComp with _beta_diver_phylum_age
set.seed(123)
mbSet<-PerformBetaDiversity(mbSet,
                            "../output_files/betadiversity/beta_diver_phylum_age",
                            "PCoA","bray","expfac","age_cat","none","Phylum",
                            "", "Shannon", "yes", "adonis", "png", 72, 
                            "default", "true");
mbSet<-PerformBetaDiversity(mbSet,
                            "../output_files/betadiversity/beta_diver_phylum_age_no_ellipse",
                            "PCoA","bray","expfac","age_cat","none","Phylum",
                            "", "Shannon", "no", "adonis", "png", 72, 
                            "default", "true");
mbSet<-PCoA3D.Anal(mbSet, 
                   "PCoA","bray","Phylum","expfac","age_cat", "","Shannon",
                   "../output_files/betadiversity/beta_diver3d_phylum_age.json"); 
mbSet<-PerformCategoryComp(mbSet, 
                           "Phylum", "adonis","bray","age_cat","true")
mbSet[["analSet"]][["stat.info.vec"]];
bd_phy_age_sig<-mbSet[["analSet"]][["stat.info.vec"]];
bd_phy_age_sig_df <- as.data.frame(bd_phy_age_sig);
bd_phy_age_sig_df$row.names <- rownames(bd_phy_age_sig_df);
write_csv(bd_phy_age_sig_df, 
          "../output_files/betadiversity/beta_diver_phylum_age_sig.csv");
```

